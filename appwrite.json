                    "required": true,
                    "array": false,
                    "size": 50,
                    "default": null,
                    "encrypt": false
                },
                {
                    "key": "scheduled_time",
                    "type": "string",
                    "required": false,
                    "array": false,
                    "size": 50,
                    "default": null,
                    "encrypt": false
                },
                {
                    "key": "timestamp",
                    "type": "datetime",
                    "required": true,
                    "array": false,
                    "format": "",
                    "default": null
                }
            ],
            "indexes": [
                {
                    "key": "timestamp_index",
                    "type": "key",
                    "status": "available",
                    "attributes": [
                        "timestamp"
                    ],
                    "orders": [
                        "DESC"
                    ]
                },
                {
                    "key": "status_index",
                    "type": "key",
                    "status": "available",
                    "attributes": [
                        "status"
                    ],
                    "orders": []
