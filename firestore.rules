rules_version = '2';
service cloud.firestore {
match /databases/{database}/documents {
// Check if user is authenticated
function isAuthenticated() {
return request.auth != null;
}

// Check if user is a super admin
function isSuperAdmin() {
return isAuthenticated() &&
exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super-admin';
}

// Check if user is clinic admin or clinic super admin
function isClinicAdminOrSuperAdmin() {
return isAuthenticated() &&
exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-admin' ||
 get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-super-admin');
}

// Check if the system is uninitialized
function isSystemUninitialized() {
return !exists(/databases/$(database)/documents/system_config/system_status) ||
!get(/databases/$(database)/documents/system_config/system_status).data.initialized ;
}

// Allow initial system setup without authentication
match /system_config/{document} {
allow read: if true                                       ;
allow write: if isSystemUninitialized() || isSuperAdmin() ;
}

// Users collection rules
match /users/{userId} {
// Helper function to check if user is clinic admin for the same clinic
function isClinicAdminForSameClinic(targetUserClinicId) {
  return isAuthenticated() &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-admin' &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == targetUserClinicId;
}

// Helper function to check if user belongs to the same clinic
function belongsToSameClinic(targetUserClinicId) {
  return isAuthenticated() &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == targetUserClinicId;
}

// Anyone authenticated can read user data (for staff management, patient assignments, etc.)
allow read: if isAuthenticated();

// Allow new users to create their own document, super admins to create any user,
// or clinic admins/super admins to create users for their clinic
allow create: if isSystemUninitialized() ||
              isSuperAdmin() ||
              (request.auth.uid == userId) ||
              (isClinicAdminOrSuperAdmin() &&
               request.resource.data.clinicId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId);

// Users can update their own data, super admins can update any user,
// or clinic admins can update users in their clinic (for role management, activation/deactivation)
allow update: if isAuthenticated() && (
              request.auth.uid == userId || 
              isSuperAdmin() ||
              isClinicAdminForSameClinic(resource.data.clinicId)
              );

// Only super admins can delete users (clinic admins should deactivate instead)
allow delete: if isSuperAdmin();
}

// Users collection-level rules for queries
match /users {
// Helper function to check if user belongs to any clinic (for listing their clinic's staff)
function belongsToAnyClinic() {
  return isAuthenticated() &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId != null;
}

// Allow clinic users to query users (they'll be filtered by clinicId in the query)
// Also allow email-based queries for password reset functionality
allow list: if isAuthenticated() && (isSuperAdmin() || belongsToAnyClinic());
}

// Special rule for email-based user queries (for password reset)
match /users {
  // Allow querying by email for password reset functionality
  // This allows authenticated users to find users by email
  allow list: if isAuthenticated();
}

// Roles collection rules
match /roles/{roleId} {
// Helper function to check if user belongs to the role's clinic
function belongsToRoleClinic() {
  return isAuthenticated() &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == resource.data.clinicId;
}

// Helper function to check if user is clinic admin/super admin for the role's clinic
function isClinicAdminForRoleClinic() {
  return isAuthenticated() &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-super-admin') &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == resource.data.clinicId;
}

// Allow authenticated users to read roles (system roles have null clinicId, clinic roles are filtered by clinic)
allow read: if isAuthenticated() && 
            (resource.data.clinicId == null || belongsToRoleClinic() || isSuperAdmin());

// Allow writes during initialization, by super admin, or by clinic admin/super admin for their clinic's roles
allow create: if isSystemUninitialized() || 
              isSuperAdmin() || 
              (isClinicAdminOrSuperAdmin() &&
               request.resource.data.clinicId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId &&
               request.resource.data.createdBy == request.auth.uid);

allow update: if isSystemUninitialized() || 
              isSuperAdmin() || 
              isClinicAdminForRoleClinic();

allow delete: if isSystemUninitialized() || 
              isSuperAdmin() || 
              isClinicAdminForRoleClinic();
}

// Roles collection-level rules for queries
match /roles {
// Helper function to check if user belongs to any clinic (for listing their clinic's roles)
function belongsToAnyClinic() {
  return isAuthenticated() &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId != null;
}

// Allow clinic users to query roles (they'll be filtered by clinicId in the query)
allow list: if isAuthenticated() && (isSuperAdmin() || belongsToAnyClinic());
}

// User Role Assignments collection rules (RBAC many-to-many relationships)
match /user_role_assignments/{assignmentId} {
// Helper function to check if user is clinic admin/super admin for the assignment's clinic
function isClinicAdminForAssignmentClinic() {
  return isAuthenticated() &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-super-admin') &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == resource.data.clinicId;
}

// Helper function to check if user belongs to the assignment's clinic
function belongsToAssignmentClinic() {
  return isAuthenticated() &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == resource.data.clinicId;
}

// Allow clinic users to read user role assignments for their clinic
allow read: if isAuthenticated() && 
            (isSuperAdmin() || belongsToAssignmentClinic());

// Allow clinic admins/super admins to create user role assignments for their clinic
allow create: if isAuthenticated() && 
              (isSuperAdmin() || 
               (isClinicAdminOrSuperAdmin() &&
                request.resource.data.clinicId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId &&
                request.resource.data.assignedBy == request.auth.uid));

// Allow clinic admins/super admins to update user role assignments for their clinic
allow update: if isAuthenticated() && 
              (isSuperAdmin() || isClinicAdminForAssignmentClinic());

// Allow clinic admins/super admins to delete user role assignments for their clinic
allow delete: if isAuthenticated() && 
              (isSuperAdmin() || isClinicAdminForAssignmentClinic());
}

// User Role Assignments collection-level rules for queries
match /user_role_assignments {
// Helper function to check if user belongs to any clinic
function belongsToAnyClinic() {
  return isAuthenticated() &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId != null;
}

// Allow clinic users to query user role assignments (filtered by clinicId in query)
allow list: if isAuthenticated() && (isSuperAdmin() || belongsToAnyClinic());
}

// Audit Logs collection rules
match /audit_logs/{logId} {
// Helper function to check if user is super admin
function isSuperAdmin() {
  return isAuthenticated() &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super-admin';
}

// Helper function to check if user belongs to the log's clinic
function belongsToLogClinic() {
  return isAuthenticated() &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == resource.data.clinicId;
}

// Only super admins can read all logs
// Clinic admins can read logs for their clinic only
allow read: if isAuthenticated() && (isSuperAdmin() || belongsToLogClinic());

// Any authenticated user can create audit logs (they're system-generated by the application)
// The system ensures only valid operations create logs
allow create: if isAuthenticated() && 
              request.resource.data.performedBy == request.auth.uid;

// No updates or deletes allowed (audit logs are immutable)
allow update, delete: if false;
}

// Audit Logs collection-level rules for queries
match /audit_logs {
// Helper function to check if user belongs to any clinic
function belongsToAnyClinic() {
  return isAuthenticated() &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId != null;
}

// Allow super admins to query all logs
// Allow clinic users to query logs (they'll be filtered by clinicId in the query)
allow list: if isAuthenticated() && (isSuperAdmin() || belongsToAnyClinic());
}

// Clinics collection rules
match /clinics/{clinicId} {
// Helper function to check if user is clinic admin/super admin for the clinic
function isClinicAdminForClinic() {
  return isAuthenticated() &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-super-admin') &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == clinicId;
}

// Only super admins can list all clinics or create new ones
allow list, create: if isSuperAdmin();

// Allow clinic members to read their own clinic data
allow get: if isAuthenticated();

// Allow super admins to update any clinic
// Allow clinic admins/super admins to update their own clinic's basic information
// Allow any clinic member to update SMS count for their clinic
allow update: if isSuperAdmin() || 
              isClinicAdminForClinic() ||
              (isAuthenticated() && 
               exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == clinicId &&
               // Only allow updating smsCount field (for increment operations)
               request.resource.data.diff(resource.data).affectedKeys().hasOnly(['smsCount']));

allow delete: if isSuperAdmin();
}

// Branches collection rules
match /branches/{branchId} {
// Helper function to check if user belongs to the branch's clinic
function belongsToBranchClinic() {
  return isAuthenticated() &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == resource.data.clinicId;
}

// Helper function to check if user is clinic admin/super admin for the branch's clinic
function isClinicAdminForBranchClinic() {
  return isAuthenticated() &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-super-admin') &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == resource.data.clinicId;
}

// Allow super admins and clinic members to read branch data
allow read: if isSuperAdmin() || belongsToBranchClinic();

// Allow super admins and clinic admins to create branches
allow create: if isSuperAdmin() || 
              (isAuthenticated() && 
               (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-admin' ||
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-super-admin') &&
               request.resource.data.clinicId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId);

// Allow super admins and clinic admins to update branches
allow update: if isSuperAdmin() || isClinicAdminForBranchClinic();

// Allow super admins and clinic admins to delete branches
allow delete: if isSuperAdmin() || isClinicAdminForBranchClinic();
}

// Branches collection-level rules for queries
match /branches {
// Helper function to check if user belongs to any clinic
function belongsToAnyClinic() {
  return isAuthenticated() &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId != null;
}

// Allow super admins to list all branches, clinic users to query their clinic's branches
allow list: if isSuperAdmin() || belongsToAnyClinic();
}

// Clinic Types collection rules
match /clinic_types/{typeId} {
// Anyone authenticated can read clinic types
allow read: if isAuthenticated()              ;

// Only super admins can create, update or delete clinic types
allow create, update, delete: if isSuperAdmin()                ;
}

// Subscription Plans collection rules
match /subscriptionPlans/{planId} {
  // Allow authenticated users to read subscription plans
  allow read: if isAuthenticated();
  
  // Only super admins can create, update or delete subscription plans
  allow create, update, delete: if isSuperAdmin();
}

// Pages collection rules
match /pages/{pageId} {
  // Allow authenticated users to read pages
  allow read: if isAuthenticated();
  
  // Only super admins can create, update or delete pages
  allow create, update, delete: if isSuperAdmin();
}

// ClinicTypePages collection rules (relation between clinic types and pages)
match /clinic_type_pages/{relationId} {
  // Allow authenticated users to read clinic type page relations
  allow read: if isAuthenticated();
  
  // Only super admins can create, update or delete clinic type page relations
  allow create, update, delete: if isSuperAdmin();
}

// Impersonation credentials collection rules
match /impersonation_credentials/{adminId} {
  // Super admins can access all
  allow read, write: if isSuperAdmin();
  
  // Clinic admins/super admins can store credentials (they should only create users for their clinic)
  allow write: if isClinicAdminOrSuperAdmin() &&
               request.resource.data.keys().hasAll(['adminId', 'email', 'encryptedPassword']) &&
               request.resource.data.adminId == adminId;
  
  // Clinic admins/super admins can read credentials they stored for their clinic
  allow read: if isClinicAdminOrSuperAdmin() &&
              exists(/databases/$(database)/documents/users/$(adminId)) &&
              get(/databases/$(database)/documents/users/$(adminId)).data.clinicId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId;
  
  // Allow updates during password reset (when user is authenticated)
  allow update: if isAuthenticated() &&
                request.resource.data.keys().hasAll(['adminId', 'email', 'encryptedPassword']) &&
                request.resource.data.adminId == adminId;
}

// Invitations collection rules
match /invitations/{invitationId} {
  // Helper function to check if user is clinic admin/super admin for the invitation's clinic
  function isClinicAdminForInvitationClinic() {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-admin' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-super-admin') &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == resource.data.clinicId;
  }

  // Helper function to check if user belongs to the invitation's clinic
  function belongsToInvitationClinic() {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == resource.data.clinicId;
  }

  // Allow clinic members to read invitations for their clinic, super admins can read all
  allow read: if isAuthenticated() && 
              (isSuperAdmin() || belongsToInvitationClinic());

  // Allow clinic admins/super admins to create invitations for their clinic, super admins can create any
  allow create: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (isClinicAdminOrSuperAdmin() &&
                  request.resource.data.clinicId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId &&
                  request.resource.data.invitedBy == request.auth.uid));

  // Allow clinic admins/super admins to update (cancel) invitations for their clinic, super admins can update any
  allow update: if isAuthenticated() && 
                (isSuperAdmin() || isClinicAdminForInvitationClinic());

  // Allow clinic admins/super admins to delete invitations for their clinic, super admins can delete any
  allow delete: if isAuthenticated() && 
                (isSuperAdmin() || isClinicAdminForInvitationClinic());
}

// Invitations collection-level rules for queries
match /invitations {
  // Helper function to check if user belongs to any clinic (for listing their own clinic's invitations)
  function belongsToAnyClinic() {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId != null;
  }
  
  // Allow clinic users to query invitations (they'll be filtered by clinicId in the query)
  allow list: if isAuthenticated() && (isSuperAdmin() || belongsToAnyClinic());
}

// Appointment Types collection rules
match /appointment_types/{appointmentTypeId} {
  // Helper function to check if user belongs to the clinic
  function belongsToClinic(clinicId) {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == clinicId;
  }
  
  // Helper function to check if user belongs to the clinic and branch (or is clinic-super-admin)
  // Also handles individual clinics where branchId might be null
  function belongsToClinicAndBranch(clinicId, branchId) {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == clinicId &&
           (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-super-admin' ||
            branchId == null || // Individual clinic case - no branch restriction
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.branchId == branchId ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.branchId == null); // User also from individual clinic
  }
  
  // Helper function for simple clinic-only access (for reading across branches)
  function belongsToClinicOnly(clinicId) {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == clinicId;
  }
  
  // Allow clinic users to read their own clinic's appointment types
  allow read: if isAuthenticated() && 
              (isSuperAdmin() || 
               (resource.data.clinicId != null && 
                belongsToClinicOnly(resource.data.clinicId)));
  
  // Allow clinic users to create appointment types for their own clinic
  // branchId is optional for individual clinics
  allow create: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (request.resource.data.clinicId != null && 
                  belongsToClinicOnly(request.resource.data.clinicId) &&
                  request.resource.data.keys().hasAll(['name', 'price', 'clinicId', 'createdBy', 'isActive']) &&
                  request.resource.data.createdBy == request.auth.uid));
  
  // Allow clinic users to update their own clinic's appointment types
  allow update: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (resource.data.clinicId != null && 
                  belongsToClinicOnly(resource.data.clinicId) &&
                  request.resource.data.clinicId == resource.data.clinicId));
  
  // Allow clinic users to delete their own clinic's appointment types
  allow delete: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (resource.data.clinicId != null && 
                  belongsToClinicOnly(resource.data.clinicId)));
}

// Appointment Types collection-level rules for queries
match /appointment_types {
  // Helper function to check if user belongs to any clinic (for listing their own clinic's data)
  function belongsToAnyClinic() {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId != null;
  }
  
  // Allow clinic users to query appointment types (they'll be filtered by clinicId and branchId in the query)
  allow list: if isAuthenticated() && (isSuperAdmin() || belongsToAnyClinic());
}

// Patients collection rules
match /patients/{patientId} {
  // Helper function to check if user belongs to the clinic
  function belongsToClinic(clinicId) {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == clinicId;
  }
  
  // Allow clinic users to read their own clinic's patients
  allow read: if isAuthenticated() && 
              (isSuperAdmin() || 
               (resource.data.clinicId != null && belongsToClinic(resource.data.clinicId)));
  
  // Allow clinic users to create patients for their own clinic
  allow create: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (request.resource.data.clinicId != null && 
                  belongsToClinic(request.resource.data.clinicId) &&
                  request.resource.data.createdBy == request.auth.uid));
  
  // Allow clinic users to update their own clinic's patients
  allow update: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (resource.data.clinicId != null && 
                  belongsToClinic(resource.data.clinicId) &&
                  request.resource.data.clinicId == resource.data.clinicId));
  
  // Allow clinic users to delete their own clinic's patients
  allow delete: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (resource.data.clinicId != null && 
                  belongsToClinic(resource.data.clinicId)));
}

// Patients collection-level rules for queries
match /patients {
  // Helper function to check if user belongs to any clinic (for listing their own clinic's data)
  function belongsToAnyClinic() {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId != null;
  }
  
  // Allow clinic users to query patients (they'll be filtered by clinicId in the query)
  allow list: if isAuthenticated() && (isSuperAdmin() || belongsToAnyClinic());
}

// Appointments collection rules
match /appointments/{appointmentId} {
  // Helper function to check if user belongs to the clinic
  function belongsToClinic(clinicId) {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == clinicId;
  }
  
  // Allow clinic users to read their own clinic's appointments
  allow read: if isAuthenticated() && 
              (isSuperAdmin() || 
               (resource.data.clinicId != null && belongsToClinic(resource.data.clinicId)));
  
  // Allow clinic users to create appointments for their own clinic
  allow create: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (request.resource.data.clinicId != null && 
                  belongsToClinic(request.resource.data.clinicId) &&
                  request.resource.data.createdBy == request.auth.uid));
  
  // Allow clinic users to update their own clinic's appointments
  allow update: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (resource.data.clinicId != null && 
                  belongsToClinic(resource.data.clinicId) &&
                  request.resource.data.clinicId == resource.data.clinicId));
  
  // Allow clinic users to delete their own clinic's appointments
  allow delete: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (resource.data.clinicId != null && 
                  belongsToClinic(resource.data.clinicId)));
}

// Appointments collection-level rules for queries
match /appointments {
  // Helper function to check if user belongs to any clinic (for listing their own clinic's data)
  function belongsToAnyClinic() {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId != null;
  }
  
  // Allow clinic users to query appointments (they'll be filtered by clinicId in the query)
  allow list: if isAuthenticated() && (isSuperAdmin() || belongsToAnyClinic());
}

// Patient Contacts collection rules
match /patient_contacts/{contactId} {
  // Helper function to check if user belongs to the clinic by checking the associated patient
  function belongsToClinicThroughPatient(patientId) {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           exists(/databases/$(database)/documents/patients/$(patientId)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == 
           get(/databases/$(database)/documents/patients/$(patientId)).data.clinicId;
  }
  
  // Allow clinic users to read patient contacts for their clinic's patients
  allow read: if isAuthenticated() && 
              (isSuperAdmin() || 
               (resource.data.patientId != null && 
                belongsToClinicThroughPatient(resource.data.patientId)));
  
  // Allow clinic users to create patient contacts for their clinic's patients
  allow create: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (request.resource.data.patientId != null && 
                  belongsToClinicThroughPatient(request.resource.data.patientId)));
  
