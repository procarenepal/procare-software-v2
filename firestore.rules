// Prescription Templates collection-level rules for queries
match /prescriptionTemplates {
  // Helper function to check if user belongs to any clinic
  function belongsToAnyClinic() {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId != null;
  }
  
  // Allow clinic users to query prescription templates (filtered by clinicId in query)
