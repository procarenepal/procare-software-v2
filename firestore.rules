// Doctor Commissions collection rules
match /doctorCommissions/{commissionId} {
  // Helper function to check if user belongs to the clinic
  function belongsToClinic(clinicId) {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == clinicId;
  }

  // Helper function to check if user has commission access
  function hasCommissionAccess(clinicId) {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-admin' || 
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-super-admin' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff') &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == clinicId;
  }

  // Allow clinic users to read their own clinic's doctor commissions
  allow read: if isAuthenticated() && 
              (isSuperAdmin() || belongsToClinic(resource.data.clinicId));
  
  // Allow clinic users with commission access to create commission records for their own clinic
  allow create: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (hasCommissionAccess(request.resource.data.clinicId) && 
                  request.resource.data.clinicId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId &&
                  request.resource.data.createdBy == request.auth.uid &&
                  request.resource.data.keys().hasAll(['doctorId', 'clinicId', 'billingId', 'commissionAmount', 'commissionPercentage', 'status', 'createdBy']) &&
                  request.resource.data.status in ['pending', 'paid', 'cancelled'] &&
                  request.resource.data.commissionAmount is number && request.resource.data.commissionAmount >= 0 &&
                  request.resource.data.commissionPercentage is number && request.resource.data.commissionPercentage >= 0 &&
                  request.resource.data.doctorId is string &&
                  request.resource.data.clinicId is string &&
                  request.resource.data.billingId is string));
  
  // Allow clinic users with commission access to update their own clinic's commission records
  allow update: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (hasCommissionAccess(resource.data.clinicId) &&
                  resource.data.clinicId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId &&
                  // Ensure clinicId and core fields don't change
                  request.resource.data.clinicId == resource.data.clinicId &&
                  request.resource.data.doctorId == resource.data.doctorId &&
                  request.resource.data.billingId == resource.data.billingId &&
                  // Ensure commission amount and percentage validations
                  request.resource.data.commissionAmount is number && request.resource.data.commissionAmount >= 0 &&
                  request.resource.data.commissionPercentage is number && request.resource.data.commissionPercentage >= 0 &&
                  request.resource.data.totalInvoiceAmount is number && request.resource.data.totalInvoiceAmount >= 0 &&
                  request.resource.data.status in ['pending', 'paid', 'cancelled']));
  
  // Allow clinic admins to delete their own clinic's commission records
  allow delete: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (hasCommissionAccess(resource.data.clinicId) &&
                  resource.data.clinicId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId));
}

