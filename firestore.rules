// Patient Notes collection rules
match /patientNotes/{notesId} {
  // Helper function to check if user belongs to the clinic by checking the associated patient
  function belongsToClinicThroughPatient(patientId) {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           exists(/databases/$(database)/documents/patients/$(patientId)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == 
           get(/databases/$(database)/documents/patients/$(patientId)).data.clinicId;
  }
  
  // Helper function to check if user belongs to the clinic directly
  function belongsToClinic(clinicId) {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == clinicId;
  }
  
  // Helper function to extract clinicId from document ID pattern: {clinicId}_{patientId}
  function getClinicIdFromNotesId(notesId) {
    return notesId.split('_')[0];
  }
  
  // Helper function to extract patientId from document ID pattern: {clinicId}_{patientId}
  function getPatientIdFromNotesId(notesId) {
    return notesId.split('_')[1];
  }
  
  // Allow clinic users to read patient notes for their clinic's patients
  // This handles both existing and non-existing documents
  allow read: if isAuthenticated() && 
              (isSuperAdmin() || 
               // For existing documents, check the data
               (resource != null && resource.data.clinicId != null && 
                belongsToClinic(resource.data.clinicId)) ||
               // For non-existing documents or when accessing by ID pattern
               (notesId.matches('.*_.*') && 
                belongsToClinic(getClinicIdFromNotesId(notesId))));
  
  // Allow clinic users to create patient notes for their clinic's patients
  allow create: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (request.resource.data.clinicId != null && 
                  belongsToClinic(request.resource.data.clinicId) &&
                  request.resource.data.patientId != null));
  
  // Allow clinic users to update patient notes for their clinic's patients
  allow update: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (resource.data.clinicId != null && 
                  belongsToClinic(resource.data.clinicId) &&
                  request.resource.data.clinicId == resource.data.clinicId));
  
  // Allow clinic users to delete patient notes for their clinic's patients
  allow delete: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (resource.data.clinicId != null && 
                  belongsToClinic(resource.data.clinicId)));
}

