                  request.resource.data.clinicId == resource.data.clinicId));
  
  // Allow clinic users to delete their own clinic's bed allotments
  allow delete: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (resource.data.clinicId != null && 
                  belongsToClinic(resource.data.clinicId)));
}

// Bed Allotments collection-level rules for queries
match /bedAllotments {
  // Helper function to check if user belongs to any clinic
  function belongsToAnyClinic() {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId != null;
  }
  
  // Allow clinic users to query bed allotments (filtered by clinicId in query)
  allow list: if isAuthenticated() && (isSuperAdmin() || belongsToAnyClinic());
}

// ProCare Nepal listing site: practice users (clinics and doctors)
match /practice_users/{userId} {
  allow read, write: if request.auth != null && request.auth.uid == userId;
}

// ProCare Nepal listing site: clinics (public read when verified; owner/platform admin write)
match /procarenepal_clinics/{clinicId} {
  allow read: if true;
  allow create: if request.auth != null;
  allow update, delete: if request.auth != null &&
    (resource.data.createdBy == request.auth.uid ||
     exists(/databases/$(database)/documents/platform_admins/$(request.auth.uid)));
}

// ProCare Nepal listing site: doctors (public read when verified; owner/platform admin write)
match /procarenepal_doctors/{doctorId} {
  allow read: if resource.data.verificationStatus == 'verified' ||
    (request.auth != null && (resource.data.uid == request.auth.uid ||
      exists(/databases/$(database)/documents/platform_admins/$(request.auth.uid))));
  allow create: if request.auth != null && 
    request.resource.data.uid == request.auth.uid &&
    (request.resource.data.doctorType == 'individual' || request.resource.data.doctorType == null);
  allow update, delete: if request.auth != null &&
    (resource.data.uid == request.auth.uid ||
     exists(/databases/$(database)/documents/platform_admins/$(request.auth.uid)));
}

// ProCare Nepal: clinic-associated doctors (created by clinics)
match /procarenepal_clinic_doctors/{doctorId} {
  // Helper: Check if user owns the clinic
  function isClinicOwner(clinicId) {
    return request.auth != null &&
           exists(/databases/$(database)/documents/practice_users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/practice_users/$(request.auth.uid)).data.clinicId == clinicId;
  }
  
  // Helper: Check if user is platform admin
  function isPlatformAdmin() {
    return request.auth != null &&
           exists(/databases/$(database)/documents/platform_admins/$(request.auth.uid));
  }
  
  // Read: Clinic owners can read their doctors, public can read verified public doctors
  allow read: if (resource.data.verificationStatus == 'verified' && resource.data.isPublic == true && resource.data.isActive == true && resource.data.isDeleted != true) ||
              (request.auth != null && (
                isClinicOwner(resource.data.clinicId) ||
                isPlatformAdmin()
              ));
  
  // Create: Only clinic owners can create doctors for their clinic
  // Clinic doctors are automatically verified (no platform admin verification needed)
  // Enforce constraint: Clinic doctors do NOT have services - they inherit from clinic
  allow create: if request.auth != null &&
                request.resource.data.clinicId is string &&
                isClinicOwner(request.resource.data.clinicId) &&
                request.resource.data.doctorType == 'clinic-associated' &&
                request.resource.data.createdBy == request.auth.uid &&
                request.resource.data.verificationStatus == 'verified' &&
                request.resource.data.verifiedBy == request.auth.uid &&
                !('services' in request.resource.data);
  
  // Update: Clinic owners can update their doctors
  // Note: Clinic doctors are auto-verified, so platform admins don't need to verify them
  // Enforce constraint: Clinic doctors do NOT have services - prevent setting/updating services
  // Prevent changing verificationStatus from verified (clinic doctors stay verified)
  allow update: if request.auth != null &&
                 isClinicOwner(resource.data.clinicId) &&
                 !('services' in request.resource.data) &&
                 (request.resource.data.verificationStatus == 'verified' || 
                  !('verificationStatus' in request.resource.data));
  
  // Delete: Use soft delete via update instead
  allow delete: if false;
}

// ProCare Nepal: clinic doctors collection-level queries
match /procarenepal_clinic_doctors {
  allow list: if true; // Public can query, but results filtered by rules above
}

// ProCare Nepal: appointment requests (patients book slots; doctors read/update)
match /procarenepal_appointments/{appointmentId} {
  allow create: if request.resource.data.doctorId is string
    && request.resource.data.date is string
    && request.resource.data.slotTime is string
    && request.resource.data.patientName is string
    && request.resource.data.patientPhone is string
    && request.resource.data.status == 'pending';
  allow read, update, delete: if request.auth != null
    && (get(/databases/$(database)/documents/procarenepal_doctors/$(resource.data.doctorId)).data.uid == request.auth.uid
        || exists(/databases/$(database)/documents/platform_admins/$(request.auth.uid)));
}

// ProCare Nepal platform admins (for verification)
match /platform_admins/{adminId} {
  allow read: if request.auth != null && request.auth.uid == adminId;
  allow list: if false;
  allow write: if false;
}

// ProCare Nepal catalog and patient_users (listing site)
match /patient_users/{userId} {
  allow read, write: if request.auth != null && request.auth.uid == userId;
}
match /catalog_provinces/{id} { allow read: if true; allow write: if false; }
match /catalog_districts/{id} { allow read: if true; allow write: if false; }
match /catalog_cities/{id} { allow read: if true; allow write: if false; }
match /catalog_services/{id} { allow read: if true; allow write: if false; }
match /catalog_clinic_types/{id} { allow read: if true; allow write: if false; }
match /catalog_specialities/{id} { allow read: if true; allow write: if false; }

// ProCare Nepal platform configuration (for admin settings)
match /platform_config/{configId} {
  // Helper: Check if user is platform admin
  function isPlatformAdmin() {
    return request.auth != null &&
           exists(/databases/$(database)/documents/platform_admins/$(request.auth.uid));
  }
  
  // Public can read (for explore page settings, etc.)
  allow read: if true;
  
  // Only platform admins can write
  allow write: if isPlatformAdmin();
}

// Default deny rule - deny all other access
match /{document=**} {
allow read, write: if false                  ;
}
}
}
