  // Allow clinic users with billing access to create billing records for their own clinic
  allow create: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (hasBillingAccess(request.resource.data.clinicId) && 
                  request.resource.data.clinicId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId &&
                  request.resource.data.createdBy == request.auth.uid &&
                  request.resource.data.keys().hasAll(['invoiceNumber', 'patientId', 'doctorId', 'totalAmount', 'clinicId'])));
  
  // Allow clinic users with billing access to update their own clinic's billing records
  allow update: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (hasBillingAccess(resource.data.clinicId) &&
                  resource.data.clinicId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId));
  
  // Allow clinic admins to delete their own clinic's billing records
  allow delete: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (hasBillingAccess(resource.data.clinicId) &&
                  resource.data.clinicId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId));
}

