// Prescription History collection rules
match /prescriptionHistory/{historyId} {
  // Helper function to check if user belongs to the prescription's clinic
  function belongsToPrescriptionClinic() {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           exists(/databases/$(database)/documents/prescriptions/$(resource.data.prescriptionId)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == 
           get(/databases/$(database)/documents/prescriptions/$(resource.data.prescriptionId)).data.clinicId;
  }
  
  // Allow clinic users to read prescription history for their clinic's prescriptions
  allow read: if isAuthenticated() && 
              (isSuperAdmin() || belongsToPrescriptionClinic());
  
  // Allow clinic users to create prescription history entries for their clinic's prescriptions
  allow create: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (belongsToPrescriptionClinic() &&
                  request.resource.data.changedBy == request.auth.uid &&
                  request.resource.data.keys().hasAll(['prescriptionId', 'changeType', 'changeDescription', 'changedBy', 'changedAt'])));
  
  // History entries should not be updated or deleted (audit trail)
  allow update, delete: if false;
}

// Prescription History collection-level rules for queries
match /prescriptionHistory {
  // Helper function to check if user belongs to any clinic
  function belongsToAnyClinic() {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId != null;
  }
  
  // Allow clinic users to query prescription history (filtered by prescriptionId in query)
  allow list: if isAuthenticated() && (isSuperAdmin() || belongsToAnyClinic());
}

