// Issued Items collection rules
match /issuedItems/{issuedItemId} {
  // Helper function to check if user belongs to the clinic
  function belongsToClinic(clinicId) {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == clinicId;
  }

  // Allow clinic users to read their own clinic's issued items
  allow read: if isAuthenticated() && 
              (isSuperAdmin() || 
               (resource.data.clinicId != null && belongsToClinic(resource.data.clinicId)));
  
  // Allow clinic users to create issued items for their own clinic
  allow create: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (request.resource.data.clinicId != null && 
                  belongsToClinic(request.resource.data.clinicId) &&
                  request.resource.data.issuedBy == request.auth.uid));
  
  // Allow clinic users to update their own clinic's issued items (for returns)
  allow update: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (resource.data.clinicId != null && 
                  belongsToClinic(resource.data.clinicId) &&
                  request.resource.data.clinicId == resource.data.clinicId));
  
  // Allow clinic users to delete their own clinic's issued items
  allow delete: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (resource.data.clinicId != null && 
                  belongsToClinic(resource.data.clinicId)));
}

// Issued Items collection-level rules for queries
match /issuedItems {
  // Helper function to check if user belongs to any clinic
  function belongsToAnyClinic() {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId != null;
  }
  
  // Allow clinic users to query issued items (they'll be filtered by clinicId in the query)
  allow list: if isAuthenticated() && (isSuperAdmin() || belongsToAnyClinic());
}

