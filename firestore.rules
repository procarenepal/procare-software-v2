match /prescriptionTemplates/{templateId} {
  // Helper function to check if user belongs to the clinic
  function belongsToClinic(clinicId) {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == clinicId;
  }
  
  // Allow clinic users to read their own clinic's prescription templates
  allow read: if isAuthenticated() && 
              (isSuperAdmin() || 
               (resource.data.clinicId != null && belongsToClinic(resource.data.clinicId)));
  
  // Allow clinic users to create prescription templates for their own clinic
  allow create: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (request.resource.data.clinicId != null && 
                  belongsToClinic(request.resource.data.clinicId) &&
                  request.resource.data.createdBy == request.auth.uid &&
                  request.resource.data.keys().hasAll(['name', 'doctorId', 'clinicId', 'branchId', 'items', 'isActive', 'createdBy'])));
  
  // Allow clinic users to update their own clinic's prescription templates
  allow update: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (resource.data.clinicId != null && 
                  belongsToClinic(resource.data.clinicId) &&
                  request.resource.data.clinicId == resource.data.clinicId));
  
  // Allow clinic users to delete their own clinic's prescription templates
  allow delete: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (resource.data.clinicId != null && belongsToClinic(resource.data.clinicId)));
