// Medical Documents collection rules
match /medical_documents/{documentId} {
  // Helper function to check if user belongs to the clinic
  function belongsToClinic(clinicId) {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == clinicId;
  }
  
  // Allow clinic users to read their own clinic's medical documents
  allow read: if isAuthenticated() && 
              (isSuperAdmin() || 
               (resource.data.clinicId != null && belongsToClinic(resource.data.clinicId)));
  
  // Allow clinic users to create medical documents for their own clinic
  allow create: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (request.resource.data.clinicId != null && 
                  belongsToClinic(request.resource.data.clinicId) &&
                  request.resource.data.createdBy == request.auth.uid &&
                  request.resource.data.keys().hasAll(['patientId', 'clinicId', 'note', 'createdBy']) &&
                  request.resource.data.keys().hasOnly(['patientId', 'clinicId', 'note', 'file', 'createdBy', 'createdAt', 'updatedAt'])));
  
  // Allow clinic users to update their own clinic's medical documents
  allow update: if isAuthenticated() && 
                (isSuperAdmin() || belongsToClinic(resource.data.clinicId));
  
  // Allow clinic users to delete their own clinic's medical documents
  allow delete: if isAuthenticated() && 
                (isSuperAdmin() || belongsToClinic(resource.data.clinicId));
}

