// ============= APPOINTMENT REMINDERS MANAGEMENT COLLECTIONS =============

// Appointment Reminders collection rules
match /appointmentReminders/{reminderId} {
  // Helper function to check if user belongs to the clinic
  function belongsToClinic(clinicId) {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == clinicId;
  }

  // Allow clinic users to read their own clinic's appointment reminders
  allow read: if isAuthenticated() && 
              (isSuperAdmin() || belongsToClinic(resource.data.clinicId));
  
  // Allow clinic users to create appointment reminders for their own clinic
  // Also allow system-level operations for automated reminders
  allow create: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (belongsToClinic(request.resource.data.clinicId) && 
                  request.resource.data.clinicId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId &&
                  request.resource.data.keys().hasAll(['appointmentId', 'patientId', 'doctorId', 'clinicId', 'appointmentDate', 'reminderDate', 'status']) &&
                  request.resource.data.status in ['scheduled', 'sent', 'failed', 'cancelled'] &&
                  request.resource.data.appointmentId is string &&
                  request.resource.data.patientId is string &&
                  request.resource.data.doctorId is string &&
                  request.resource.data.clinicId is string &&
                  // branchId is optional
                  (!request.resource.data.keys().hasAny(['branchId']) || request.resource.data.branchId is string)) ||
                 // Allow system/server-side operations (for automated reminders)
                 (request.resource.data.keys().hasAll(['appointmentId', 'patientId', 'doctorId', 'clinicId', 'appointmentDate', 'reminderDate', 'status']) &&
                  request.resource.data.status in ['scheduled', 'sent', 'failed', 'cancelled'] &&
                  request.resource.data.appointmentId is string &&
                  request.resource.data.patientId is string &&
                  request.resource.data.doctorId is string &&
                  request.resource.data.clinicId is string &&
                  // branchId is optional for system operations too
                  (!request.resource.data.keys().hasAny(['branchId']) || request.resource.data.branchId is string)));
  
  // Allow clinic users to update their own clinic's appointment reminders (for status updates)
  allow update: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (belongsToClinic(resource.data.clinicId) &&
                  request.resource.data.clinicId == resource.data.clinicId &&
                  // Ensure core fields don't change
                  request.resource.data.appointmentId == resource.data.appointmentId &&
                  request.resource.data.patientId == resource.data.patientId &&
                  request.resource.data.doctorId == resource.data.doctorId &&
                  request.resource.data.clinicId == resource.data.clinicId &&
                  request.resource.data.status in ['scheduled', 'sent', 'failed', 'cancelled']));
  
  // Allow clinic users to delete their own clinic's appointment reminders
  allow delete: if isAuthenticated() && 
                (isSuperAdmin() || belongsToClinic(resource.data.clinicId));
}

// Appointment Reminders collection-level rules for queries
match /appointmentReminders {
  // Helper function to check if user belongs to any clinic
  function belongsToAnyClinic() {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId != null;
  }

  // Allow clinic users to query appointment reminders (filtered by clinicId in query)
  allow list: if isAuthenticated() && (isSuperAdmin() || belongsToAnyClinic());
}

// ============= TEXT EDITOR DOCUMENT MANAGEMENT COLLECTIONS =============

// Text Documents collection rules
match /textDocuments/{documentId} {
  // Helper function to check if user belongs to the document's clinic
  function belongsToDocumentClinic() {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == resource.data.clinicId;
  }

  // Helper function to check if user belongs to the document's branch (for multi-branch clinics)
  function belongsToDocumentBranch() {
    return belongsToDocumentClinic() &&
           // If document has no branchId (clinic-wide), allow access
           (!('branchId' in resource.data) || resource.data.branchId == null ||
            // If user has no branchId (clinic admin), allow access
            !('branchId' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.branchId == null ||
            // If user belongs to the same branch
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.branchId == resource.data.branchId);
  }

  // Helper function to check if user is clinic admin/super admin for the document's clinic
  function isClinicAdminForDocumentClinic() {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == resource.data.clinicId &&
           (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-admin' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-super-admin' ||
            isSuperAdmin());
  }

  // Allow clinic members to read documents from their clinic/branch
  allow read: if isSuperAdmin() || belongsToDocumentBranch();

  // Allow authenticated clinic members to create documents for their clinic/branch
  allow create: if isAuthenticated() &&
                 exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                 // Must belong to the clinic they're creating document for
                 get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == request.resource.data.clinicId &&
                 // If document has branchId, user must belong to that branch or be clinic admin
                 (!('branchId' in request.resource.data) || request.resource.data.branchId == null ||
                  !('branchId' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) ||
                  get(/databases/$(database)/documents/users/$(request.auth.uid)).data.branchId == null ||
                  get(/databases/$(database)/documents/users/$(request.auth.uid)).data.branchId == request.resource.data.branchId ||
                  get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-admin' ||
                  get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-super-admin') &&
                 // Document creator must match authenticated user
                 request.resource.data.createdBy == request.auth.uid;

  // Allow document creator, clinic admins, or users from same branch to update documents
  allow update: if isAuthenticated() &&
                 belongsToDocumentBranch() &&
                 // Either document creator, clinic admin, or lastModifiedBy matches current user
                 (resource.data.createdBy == request.auth.uid ||
                  isClinicAdminForDocumentClinic() ||
                  request.resource.data.lastModifiedBy == request.auth.uid) &&
                 // Ensure clinicId and branchId cannot be changed
                 request.resource.data.clinicId == resource.data.clinicId &&
                 ((!('branchId' in resource.data) && !('branchId' in request.resource.data)) ||
                  request.resource.data.branchId == resource.data.branchId);

  // Allow document creator or clinic admins to delete documents
  allow delete: if isAuthenticated() &&
                 belongsToDocumentBranch() &&
                 (resource.data.createdBy == request.auth.uid ||
                  isClinicAdminForDocumentClinic());
}

// Text Documents collection-level rules for queries
match /textDocuments {
  // Helper function to check if user belongs to any clinic
  function belongsToAnyClinic() {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           'clinicId' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
  }

  // Allow clinic users to query documents (filtered by clinicId and optionally branchId in query)
  allow list: if isSuperAdmin() || belongsToAnyClinic();
}

