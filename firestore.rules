                (isSuperAdmin() || 
                 (hasLabTechnicianAccess(resource.data.clinicId) &&
                  resource.data.clinicId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId &&
                  // Ensure clinic ID doesn't change
                  request.resource.data.clinicId == resource.data.clinicId));
  
  // Allow clinic users with access to delete (soft delete) their own clinic's lab technicians
  allow delete: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (hasLabTechnicianAccess(resource.data.clinicId) &&
                  resource.data.clinicId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId));
}

