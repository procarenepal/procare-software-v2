// ============= PRESCRIPTION MANAGEMENT COLLECTIONS =============

// Prescriptions collection rules
match /prescriptions/{prescriptionId} {
  // Helper function to check if user belongs to the clinic
  function belongsToClinic(clinicId) {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == clinicId;
  }
  
  // Allow clinic users to read their own clinic's prescriptions
  allow read: if isAuthenticated() && 
              (isSuperAdmin() || 
               (resource.data.clinicId != null && belongsToClinic(resource.data.clinicId)));
  
  // Allow clinic users to create prescriptions for their own clinic
  allow create: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (request.resource.data.clinicId != null && 
                  belongsToClinic(request.resource.data.clinicId) &&
                  request.resource.data.createdBy == request.auth.uid &&
                  request.resource.data.keys().hasAll(['prescriptionNo', 'patientId', 'doctorId', 'prescriptionDate', 'status', 'clinicId', 'branchId', 'createdBy'])));
  
  // Allow clinic users to update their own clinic's prescriptions
  allow update: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (resource.data.clinicId != null && 
                  belongsToClinic(resource.data.clinicId) &&
                  request.resource.data.clinicId == resource.data.clinicId));
  
  // Allow clinic users to delete their own clinic's prescriptions
  allow delete: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (resource.data.clinicId != null && belongsToClinic(resource.data.clinicId)));
}

// Prescriptions collection-level rules for queries
match /prescriptions {
  // Helper function to check if user belongs to any clinic
  function belongsToAnyClinic() {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId != null;
  }
  
  // Allow clinic users to query prescriptions (filtered by clinicId in query)
  allow list: if isAuthenticated() && (isSuperAdmin() || belongsToAnyClinic());
}

// Prescription Items collection rules (sub-collection of prescriptions)
match /prescriptions/{prescriptionId}/items/{itemId} {
  // Helper function to check if user belongs to the prescription's clinic
  function belongsToPrescriptionClinic() {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           exists(/databases/$(database)/documents/prescriptions/$(prescriptionId)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == 
           get(/databases/$(database)/documents/prescriptions/$(prescriptionId)).data.clinicId;
  }
  
  // Allow clinic users to read prescription items for their clinic's prescriptions
  allow read: if isAuthenticated() && 
              (isSuperAdmin() || belongsToPrescriptionClinic());
  
  // Allow clinic users to create prescription items for their clinic's prescriptions
  allow create: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (belongsToPrescriptionClinic() &&
                  request.resource.data.createdBy == request.auth.uid &&
                  request.resource.data.keys().hasAll(['medicineId', 'medicineName', 'dosage', 'frequency', 'duration', 'time', 'isActive', 'createdBy'])));
  
  // Allow clinic users to update prescription items for their clinic's prescriptions
  allow update: if isAuthenticated() && 
                (isSuperAdmin() || belongsToPrescriptionClinic());
  
  // Allow clinic users to delete prescription items for their clinic's prescriptions
  allow delete: if isAuthenticated() && 
                (isSuperAdmin() || belongsToPrescriptionClinic());
}

