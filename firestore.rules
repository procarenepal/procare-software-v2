// Appointment Billing Settings collection rules
match /appointmentBillingSettings/{settingsId} {
  // Helper function to check if user belongs to the clinic (settingsId should be clinicId)
  function belongsToClinic(clinicId) {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == clinicId;
  }

  // Helper function to check if user is clinic admin for the clinic
  function isClinicAdminForClinic(clinicId) {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-admin' || 
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-super-admin') &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == clinicId;
  }

  // Allow clinic users to read their own clinic's billing settings (settingsId = clinicId)
  allow read: if isAuthenticated() && 
              (isSuperAdmin() || belongsToClinic(settingsId));
  
  // Allow super admins to create billing settings for any clinic, clinic admins for their own clinic
  allow create: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (belongsToClinic(settingsId) && 
                  request.resource.data.clinicId == settingsId &&
                  request.resource.data.keys().hasAll(['clinicId', 'enabledByAdmin', 'isActive', 'invoicePrefix', 'nextInvoiceNumber']) &&
                  // Validate paymentMethods array structure if present
                  (!request.resource.data.keys().hasAny(['paymentMethods']) || 
                   (request.resource.data.paymentMethods is list &&
                    request.resource.data.paymentMethods.size() >= 0)) &&
                  // Validate defaultPaymentMethod if present
                  (!request.resource.data.keys().hasAny(['defaultPaymentMethod']) || 
                   request.resource.data.defaultPaymentMethod is string)));
  
  // Allow super admins to update any clinic's billing settings, clinic admins for their own clinic
  allow update: if isAuthenticated() && 
                (isSuperAdmin() || 
                 belongsToClinic(settingsId)) &&
                // Validate paymentMethods array structure if being updated
                (!request.resource.data.keys().hasAny(['paymentMethods']) || 
                 (request.resource.data.paymentMethods is list &&
                  request.resource.data.paymentMethods.size() >= 0)) &&
                // Validate defaultPaymentMethod if being updated
                (!request.resource.data.keys().hasAny(['defaultPaymentMethod']) || 
                 request.resource.data.defaultPaymentMethod is string) &&
                // Ensure clinic ID consistency for updates
                (!request.resource.data.keys().hasAny(['clinicId']) || 
                 request.resource.data.clinicId == settingsId);
  
  // Allow super admins to delete any clinic's billing settings, clinic admins for their own clinic
  allow delete: if isAuthenticated() && 
                (isSuperAdmin() || isClinicAdminForClinic(settingsId));
}

