// SMS Settings collection rules
match /smsSettings/{settingsId} {
  // Helper function to check if user belongs to the clinic (settingsId should be clinicId)
  function belongsToClinic(clinicId) {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == clinicId;
  }

  // Helper function to check if user is clinic admin for the clinic
  function isClinicAdminForClinic(clinicId) {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-admin' || 
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-super-admin') &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == clinicId;
  }

  // Allow clinic users to read their own clinic's SMS settings (settingsId = clinicId)
  allow read: if isAuthenticated() && 
              (isSuperAdmin() || belongsToClinic(settingsId));
  
  // Allow clinic users to create SMS settings for their own clinic (settingsId = clinicId)
  allow create: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (belongsToClinic(settingsId) && 
                  request.resource.data.clinicId == settingsId &&
                  request.resource.data.enableReminders is bool &&
                  request.resource.data.reminderHours is number &&
                  request.resource.data.maxDailySMS is number &&
                  request.resource.data.currentDailySMS is number &&
                  request.resource.data.enableAutoReminders is bool &&
                  request.resource.data.isActive is bool));
  
  // Allow clinic users to update their own clinic's SMS settings
  allow update: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (belongsToClinic(settingsId) &&
                  request.resource.data.clinicId == settingsId));
  
  // Allow clinic admins to delete their own clinic's SMS settings
  allow delete: if isAuthenticated() && 
                (isSuperAdmin() || isClinicAdminForClinic(settingsId));
}

