// ============= SMS COMMUNICATION MANAGEMENT COLLECTIONS =============

// SMS Logs collection rules
match /smsLogs/{logId} {
  // Helper function to check if user belongs to the clinic
  function belongsToClinic(clinicId) {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == clinicId;
  }

  // Allow clinic users to read their own clinic's SMS logs
  allow read: if isAuthenticated() && 
              (isSuperAdmin() || belongsToClinic(resource.data.clinicId));
  
  // Allow clinic users to create SMS logs for their own clinic
  allow create: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (belongsToClinic(request.resource.data.clinicId) && 
                  request.resource.data.clinicId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId &&
                  request.resource.data.keys().hasAll(['clinicId', 'message', 'status', 'type', 'createdBy']) &&
                  request.resource.data.status in ['sent', 'failed', 'pending'] &&
                  request.resource.data.type in ['reminder', 'manual', 'template', 'appointment'] &&
                  // Optional fields validation
                  (!request.resource.data.keys().hasAny(['recipientType']) || request.resource.data.recipientType in ['patient', 'doctor', 'general']) &&
                  (!request.resource.data.keys().hasAny(['patientId']) || request.resource.data.patientId is string) &&
                  (!request.resource.data.keys().hasAny(['doctorId']) || request.resource.data.doctorId is string) &&
                  (!request.resource.data.keys().hasAny(['branchId']) || request.resource.data.branchId is string) &&
                  (!request.resource.data.keys().hasAny(['templateId']) || request.resource.data.templateId is string) &&
                  (!request.resource.data.keys().hasAny(['errorMessage']) || request.resource.data.errorMessage is string) &&
                  (!request.resource.data.keys().hasAny(['patientName']) || request.resource.data.patientName is string) &&
                  (!request.resource.data.keys().hasAny(['doctorName']) || request.resource.data.doctorName is string) &&
                  (!request.resource.data.keys().hasAny(['patientPhone']) || request.resource.data.patientPhone is string) &&
                  (!request.resource.data.keys().hasAny(['doctorPhone']) || request.resource.data.doctorPhone is string)) ||
                 // Allow system/server-side operations (for automated reminders)
                 (request.resource.data.createdBy == 'system' &&
                  request.resource.data.type == 'reminder'));
  
  // Allow clinic users to update their own clinic's SMS logs (for status updates)
  allow update: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (belongsToClinic(resource.data.clinicId) &&
                  request.resource.data.clinicId == resource.data.clinicId));
  
  // Allow clinic users to delete their own clinic's SMS logs
  allow delete: if isAuthenticated() && 
                (isSuperAdmin() || belongsToClinic(resource.data.clinicId));
}

