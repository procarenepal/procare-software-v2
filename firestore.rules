// ============= PATHOLOGY BILLING COLLECTIONS =============

// Pathology Billing Settings collection rules
match /pathologyBillingSettings/{settingsId} {
  // Helper function to check if user is clinic admin for the clinic
  function isClinicAdminForClinic(clinicId) {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic-admin' &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == clinicId;
  }

  // Helper function to check if user belongs to the clinic
  function belongsToClinic(clinicId) {
    return isAuthenticated() &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId == clinicId;
  }

  // Allow clinic users to read their own clinic's billing settings
  allow read: if isAuthenticated() && 
              (isSuperAdmin() || belongsToClinic(settingsId));
  
  // Allow clinic admins to create/update billing settings for their own clinic
  allow create, update: if isAuthenticated() && 
                (isSuperAdmin() || 
                 (isClinicAdminForClinic(settingsId) &&
                  request.resource.data.clinicId == settingsId &&
                  // Ensure clinic ID consistency for updates
                  (!request.resource.data.keys().hasAny(['clinicId']) || 
                   request.resource.data.clinicId == settingsId)));

  // Allow super admins to delete any clinic's billing settings, clinic admins for their own clinic
  allow delete: if isAuthenticated() && 
                (isSuperAdmin() || isClinicAdminForClinic(settingsId));
}

