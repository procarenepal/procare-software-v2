rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Clinic verification documents: PDF or images, max 5MB. Auth required for read/write.
    match /clinic-documents/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && (request.resource.contentType == 'application/pdf'
            || request.resource.contentType.matches('image/.*'));
    }
    // Clinic logos: images only, max 2MB. Auth required for read/write.
    match /clinic-logos/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Clinic cover photos: banner images, max 5MB. Auth required for read/write.
    match /clinic-covers/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Doctor verification documents: PDF or images, max 5MB. Auth required for read/write.
    match /doctor-documents/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && (request.resource.contentType == 'application/pdf'
            || request.resource.contentType.matches('image/.*'));
    }

    // Doctor profile/cover photos: images only, max 2MB. Public read for profile; auth write.
    match /doctor-photos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Clinic gallery photos (up to 10 per clinic, not logo/banner). Public read for profile; auth write.
    match /clinic-gallery/{clinicId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 3 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Catalog province images: banner/thumbnail images for provinces, max 5MB. Auth required.
    match /catalog_provinces/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
